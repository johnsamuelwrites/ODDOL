{
  "name": "oddol",
  "version": "2.0.0",
  "description": "Open Data Driven Online Learning - Real-time federated open data platform",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnsamuelwrites/ODDOL.git"
  },
  "keywords": [
    "Open-Data",
    "Online-Learning",
    "Education",
    "Wikidata",
    "SPARQL",
    "Federated-Search"
  ],
  "author": "John Samuel",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/johnsamuelwrites/ODDOL/issues"
  },
  "homepage": "https://github.com/johnsamuelwrites/ODDOL#readme",
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.28.0",
    "@observablehq/plot": "^0.6.14",
    "@tanstack/svelte-query": "^5.17.0",
    "comlink": "^4.4.1",
    "d3": "^7.8.5",
    "idb": "^8.0.0",
    "maplibre-gl": "^4.1.0",
    "n3": "^1.17.2",
    "simple-statistics": "^7.8.3",
    "sparqljs": "^3.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.51.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.10",
    "@types/d3": "^7.4.3",
    "@types/n3": "^1.16.4",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-svelte": "^2.35.1",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.0",
    "tailwindcss": "^3.4.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
